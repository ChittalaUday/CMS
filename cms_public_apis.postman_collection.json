							],
							"path": [
								"api",
								"public",
								"blogs"
							]
						},
						"description": "Fetches all published blog posts ordered by creation date (newest first). Included in the response are the post's author, featured image, and simplified category list."
					},
					"response": []
				},
				{
					"name": "Get Blog Post by Slug",
					"request": {
						"method": "GET",
						"header": [],
