							"raw": "{{cms_url}}/api/public/blogs/:slug",
							"host": [
								"{{cms_url}}"
							],
							"path": [
								"api",
								"public",
								"blogs",
								":slug"
							],
							"variable": [
								{
									"key": "slug",
									"value": "my-first-blog-post",
									"description": "The unique URL slug of the blog post to fetch."
								}
							]
						},
						"description": "Fetches details of a single published blog post using its unique URL slug."
					},
					"response": []
				},
				{
					"name": "Record Blog Post View",
					"request": {
						"method": "POST",
