								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"slug\": \"my-first-blog-post\",\n  \"postId\": \"\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{cms_url}}/api/public/blogs/view",
							"host": [
								"{{cms_url}}"
							],
							"path": [
								"api",
								"public",
								"blogs",
								"view"
							]
						},
						"description": "Increments the view count for a blog post. You must provide either the 'slug' or the 'postId' in the JSON body."
					},
					"response": []
				}
			]
