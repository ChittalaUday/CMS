generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HR
  EDITOR
}


enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  TEMPORARY
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum QuestionType {
  SHORT_TEXT
  LONG_TEXT
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  YES_NO
  FILE
}

enum ApplicationStatus {
  NEW
  REVIEWING
  SHORTLISTED
  REJECTED
  HIRED
}

enum QueueStatus {
  IDLE
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  username            String    @unique
  password            String
  name                String?
  avatarUrl           String?
  bio                 String?
  onboardingCompleted Boolean   @default(true)
  role                Role      @default(EDITOR)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  sessions            Session[]
  posts               Post[]
  comments            Comment[]
  likes               Like[]
  views               View[]
  media               Media[]
  jobPostings         JobPosting[]
  invitesSent         UserInvite[] @relation("InvitesSent")
  invite              UserInvite?  @relation("UserInvite")
}

model UserInvite {
  id          String    @id @default(cuid())
  token       String    @unique
  code        String    @unique
  email       String
  userId      String    @unique
  user        User      @relation("UserInvite", fields: [userId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User      @relation("InvitesSent", fields: [invitedById], references: [id])
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([token])
  @@index([code])
  @@index([userId])
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Post {
  id              String         @id @default(cuid())
  title           String
  slug            String         @unique
  content         String
  contentJson     Json?
  published       Boolean        @default(false)
  authorId        String?
  author          User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
  featuredImageId String?
  featuredImage   Media?         @relation("FeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)
  metadata        Json?          @default("{}")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Draft revision: a published post can have at most one pending revision
  draftParentId   String?
  draftParent     Post?          @relation("PostDraftVersion", fields: [draftParentId], references: [id], onDelete: Cascade)
  drafts          Post[]         @relation("PostDraftVersion")

  comments        Comment[]
  likes           Like[]
  views           View[]
  categories      PostCategory[]
  media           PostMedia[]

  @@index([authorId])
  @@index([featuredImageId])
  @@index([draftParentId])
}

model Category {
  id        String         @id @default(cuid())
  name      String         @unique
  slug      String         @unique
  createdAt DateTime       @default(now())
  posts     PostCategory[]
}

model PostCategory {
  postId     String
  categoryId String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
}

model Media {
  id            String      @id @default(cuid())
  filename      String
  url           String
  mimeType      String
  size          Int
  width         Int?
  height        Int?
  userId        String?
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  shaKey        String?     @unique

  featuredPosts Post[]      @relation("FeaturedImage")
  posts         PostMedia[]

  @@index([userId])
}


model PostMedia {
  postId  String
  mediaId String
  post    Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([postId, mediaId])
}

model Comment {
  id         String   @id @default(cuid())
  content    String
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([postId])
  @@index([authorId])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
}

model View {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
}

// --- Careers ---

model JobPosting {
  id                   String           @id @default(cuid())
  title                String
  slug                 String           @unique
  department           String
  location             String
  jobType              JobType          @default(FULL_TIME)
  description          String
  descriptionJson      Json?
  responsibilities     String?
  responsibilitiesJson Json?
  requirements         String?
  requirementsJson     Json?
  salaryMin            Int?
  salaryMax            Int?
  currency             String           @default("INR")
  status               JobStatus        @default(DRAFT)
  closingDate          DateTime?
  draftParentId        String?
  draftParent          JobPosting?      @relation("DraftVersion", fields: [draftParentId], references: [id], onDelete: Cascade)
  drafts               JobPosting[]     @relation("DraftVersion")
  createdById          String?
  createdBy            User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  questions            JobQuestion[]
  applications         JobApplication[]
  keywords             String[]         @default([])
  keywordStatus        QueueStatus      @default(IDLE)

  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([createdById])
  @@index([status])
  @@index([draftParentId])
}

model JobQuestion {
  id        String       @id @default(cuid())
  jobId     String
  job       JobPosting   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  question  String
  type      QuestionType @default(SHORT_TEXT)
  required  Boolean      @default(false)
  order     Int          @default(0)
  options   Json?
  answers   JobAnswer[]
  createdAt DateTime     @default(now())

  @@index([jobId])
}

model JobApplication {
  id               String            @id @default(cuid())
  jobId            String
  job              JobPosting        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantName    String
  applicantEmail   String
  applicantPhone   String?
  resumeUrl        String?
  coverLetter      String?
  status           ApplicationStatus @default(NEW)
  notes            String?
  answers          JobAnswer[]
  atsScore         Int?
  atsConfidence    Int?
  atsJustification String?
  extractedSkills  String[]          @default([])
  extractedExperience Int?
  extractedLocation String?
  extractedEducation String?
  atsStatus        QueueStatus       @default(PENDING)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([jobId])
  @@index([status])
  @@index([applicantEmail])
}

model JobAnswer {
  id            String         @id @default(cuid())
  applicationId String
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  questionId    String
  question      JobQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer        String

  @@index([applicationId])
  @@index([questionId])
}
