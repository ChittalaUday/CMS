# Database
DATABASE_URL="postgresql://user:password@localhost:5432/cms?schema=public"

# Cloudflare R2
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET=""
CLOUDFLARE_R2_PUBLIC_URL=""

# UploadThing
UPLOADTHING_TOKEN=""

# AI Gateway
AI_GATEWAY_API_KEY=""

# Global toggle to enable/disable showing Ollama or AI related features and icons
ENABLE_AI="true"

# Runtime (optional override — Next.js sets this automatically)
NODE_ENV="development"

# Ollama (local AI)
OLLAMA_API_URL="http://localhost:11434"
OLLAMA_MODEL="qwen3:0.6b"
OLLAMA_EMBEDDING_MODEL="all-minilm:l6-v2"
