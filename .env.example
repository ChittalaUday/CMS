# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@localhost:5432/cms?schema=public"

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare R2 (object storage)
# ─────────────────────────────────────────────────────────────────────────────
# Endpoint: https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET=""
# Public URL base for serving stored files, e.g. https://assets.example.com
CLOUDFLARE_R2_PUBLIC_URL=""

# ─────────────────────────────────────────────────────────────────────────────
# UploadThing (editor file uploads)
# Get your token at https://uploadthing.com/dashboard
# ─────────────────────────────────────────────────────────────────────────────
UPLOADTHING_TOKEN=""

# ─────────────────────────────────────────────────────────────────────────────
# AI Gateway (Anthropic / Claude)
# ─────────────────────────────────────────────────────────────────────────────
AI_GATEWAY_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# Runtime
# ─────────────────────────────────────────────────────────────────────────────
# Controls error verbosity: "development" shows raw DB/stack traces in the UI;
# any other value (e.g. "production") shows generic user-safe messages only.
# Next.js sets this automatically — only override if running outside Next.js.
# NODE_ENV="development"
